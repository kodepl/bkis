---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const categories = [...new Set(posts.map(p => p.data.category))];

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout title="All Broadcasts" description="Browse all broadcasts from BKIS Radio Network.">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="flex items-center gap-3 mb-2">
      <span class="section-label">Archive</span>
    </div>
    <h1 class="headline-display mb-8">All Broadcasts</h1>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="space-y-4">
          {sortedPosts.map((post) => (
            <article class="radio-card p-4 flex gap-4 group">
              <a href={`/blog/${post.slug}/`} class="shrink-0 w-32 md:w-44">
                <img src={post.data.heroImage} alt={post.data.title} class="w-full aspect-video object-cover rounded group-hover:opacity-80 transition" />
              </a>
              <div class="flex-1">
                <span class="freq-badge">{post.data.category}</span>
                <h2 class="font-display text-lg font-semibold mt-2 mb-1">
                  <a href={`/blog/${post.slug}/`} class="hover:text-radio-green transition">{post.data.title}</a>
                </h2>
                <p class="text-radio-muted text-sm line-clamp-2 mb-2">{post.data.description}</p>
                <div class="flex items-center gap-3">
                  <span class="article-meta">{formatDate(post.data.pubDate)}</span>
                  <span class="article-meta">{Math.ceil(post.body.length / 200)} min</span>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <aside>
        <div class="radio-card p-5">
          <h3 class="section-label mb-4">Channels</h3>
          <div class="space-y-2">
            {categories.map(cat => (
              <a href={`/tag/${cat.toLowerCase().replace(/\s+/g, '-')}/`} class="flex items-center justify-between py-2 border-b border-radio-border last:border-0 hover:text-radio-green transition">
                <span class="font-mono text-sm">{cat}</span>
                <span class="font-mono text-xs text-radio-muted">{posts.filter(p => p.data.category === cat).length}</span>
              </a>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
