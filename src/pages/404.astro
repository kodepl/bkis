---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Signal Lost">
  <div class="max-w-7xl mx-auto px-4 py-24 text-center">
    <div class="font-mono text-8xl font-bold text-radio-green mb-4">404</div>
    <div class="font-mono text-lg text-radio-muted mb-2">SIGNAL LOST</div>
    <p class="text-radio-muted mb-8">This frequency is not broadcasting.</p>
    <a href="/" class="inline-flex items-center gap-2 bg-radio-green text-radio-dark font-mono text-sm font-medium px-6 py-3 rounded hover:bg-radio-green-dim transition">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
      Return to Station
    </a>
  </div>
</BaseLayout>
